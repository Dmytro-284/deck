# Deckforge auth + cloud save — required env vars.
# Custom signed-cookie auth (NOT Supabase Auth); Supabase used as DB via service role.

# Supabase project ikicfkfscigshglvtpws
SUPABASE_URL=https://ikicfkfscigshglvtpws.supabase.co
SUPABASE_SERVICE_KEY=            # service_role key (server-only, bypasses RLS)

# Session signing — must be >= 16 chars or auth throws.
SESSION_SECRET=

# Public base URL — only needed for local dev. On Vercel it auto-derives from
# VERCEL_PROJECT_PRODUCTION_URL (the stable prod domain).
# NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Google OAuth (redirect URI: ${NEXT_PUBLIC_BASE_URL}/api/auth/google/callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Telegram OAuth/OIDC (redirect URI: ${NEXT_PUBLIC_BASE_URL}/api/auth/telegram/callback)
TELEGRAM_CLIENT_ID=
TELEGRAM_CLIENT_SECRET=

# Optional — password-reset emails. Without it, reset links are logged to the server console.
RESEND_API_KEY=
